generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER  @map("user")
  ADMIN @map("admin")

  @@map("user_role")
}

enum SocialProvider {
  GOOGLE @map("google")
  KAKAO  @map("kakao")

  @@map("social_provider")
}

enum Visibility {
  PUBLIC  @map("public")
  PRIVATE @map("private")

  @@map("visibility")
}

enum HistoryAction {
  CREATE
  UPDATE
  DELETE

  @@map("history_action")
}

model User {
  id                BigInt    @id @default(autoincrement())
  uuid              String    @unique @default(uuid()) @db.Uuid
  email             String    @unique @db.VarChar(255)
  password          String?   @db.VarChar(255)
  nickname          String    @db.VarChar(50)
  profileImg        String?   @map("profile_img") @db.VarChar(500)
  role              UserRole  @default(USER)
  emailVerified     Boolean   @default(false) @map("email_verified")
  deletedAt         DateTime? @map("deleted_at")
  scheduledDeleteAt DateTime? @map("scheduled_delete_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  socialAccounts SocialAccount[]
  posts          Post[]
  tags           Tag[]
  categories     Category[]
  routines       Routine[]
  histories      History[]       @relation("HistoryChangedBy")
  refreshTokens  RefreshToken[]

  @@index([scheduledDeleteAt])
  @@map("users")
}

model SocialAccount {
  id             BigInt         @id @default(autoincrement())
  userId         BigInt         @map("user_id")
  provider       SocialProvider
  providerUserId String         @map("provider_user_id") @db.VarChar(255)
  email          String?        @db.VarChar(255)
  emailVerified  Boolean        @default(false) @map("email_verified")
  createdAt      DateTime       @default(now()) @map("created_at")
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@unique([userId, provider])
  @@map("social_accounts")
}

model Post {
  id         BigInt     @id @default(autoincrement())
  uuid       String     @unique @default(uuid()) @db.Uuid
  userId     BigInt     @map("user_id")
  categoryId BigInt     @map("category_id")
  title      String     @db.VarChar(255)
  content    Json
  weather    String?    @db.VarChar(50)
  visibility Visibility @default(PUBLIC)
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")

  user               User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  category           Category     @relation("CategoryPosts", fields: [categoryId], references: [id], onDelete: Restrict)
  featuredInCategory Category[]   @relation("FeaturedPost")
  postTags           PostTag[]
  images             PostImage[]
  postRoutine        PostRoutine?

  @@index([userId])
  @@index([categoryId])
  @@map("posts")
}

model Tag {
  id       BigInt    @id @default(autoincrement())
  userId   BigInt    @map("user_id")
  name     String    @db.VarChar(50)
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  postTags PostTag[]

  @@unique([userId, name])
  @@map("tags")
}

model PostTag {
  postId BigInt @map("post_id")
  tagId  BigInt @map("tag_id")
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@index([tagId])
  @@map("post_tags")
}

model PostImage {
  id        BigInt   @id @default(autoincrement())
  postId    BigInt   @map("post_id")
  imageUrl  String   @map("image_url") @db.VarChar(500)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, sortOrder])
  @@map("post_images")
}

model Category {
  id                BigInt     @id @default(autoincrement())
  userId            BigInt     @map("user_id")
  featuredPostId    BigInt?    @map("featured_post_id")
  name              String     @db.VarChar(50)
  defaultVisibility Visibility @default(PUBLIC) @map("default_visibility")
  isActive          Boolean    @default(true) @map("is_active")
  createdAt         DateTime   @default(now()) @map("created_at")
  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  posts             Post[]     @relation("CategoryPosts")
  featuredPost      Post?      @relation("FeaturedPost", fields: [featuredPostId], references: [id], onDelete: SetNull)

  @@unique([userId, name])
  @@index([featuredPostId])
  @@map("categories")
}

model Routine {
  id           BigInt          @id @default(autoincrement())
  uuid         String          @unique @default(uuid()) @db.Uuid
  userId       BigInt          @map("user_id")
  title        String          @db.VarChar(100)
  startDate    DateTime        @map("start_date") @db.Date
  endDate      DateTime?       @map("end_date") @db.Date
  isActive     Boolean         @default(true) @map("is_active")
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  settings     RoutineSetting?
  postRoutines PostRoutine[]

  @@unique([userId, title])
  @@map("routines")
}

model RoutineSetting {
  id            BigInt    @id @default(autoincrement())
  routineId     BigInt    @unique @map("routine_id")
  time          DateTime? @db.Time(0)
  repeatContent Json      @map("repeat_content")
  note          String?   @db.VarChar(500)
  updatedAt     DateTime  @updatedAt @map("updated_at")
  routine       Routine   @relation(fields: [routineId], references: [id], onDelete: Cascade)

  @@map("routine_settings")
}

model PostRoutine {
  id            BigInt    @id @default(autoincrement())
  postId        BigInt    @unique @map("post_id")
  routineId     BigInt    @map("routine_id")
  time          DateTime? @db.Time(0)
  repeatContent Json      @map("repeat_content")
  note          String?   @db.VarChar(500)
  createdAt     DateTime  @default(now()) @map("created_at")
  post          Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  routine       Routine   @relation(fields: [routineId], references: [id], onDelete: Cascade)

  @@index([routineId])
  @@map("post_routines")
}

model History {
  id            BigInt        @id @default(autoincrement())
  tableName     String        @map("table_name") @db.VarChar(50)
  recordId      BigInt        @map("record_id")
  action        HistoryAction
  beforeData    Json?         @map("before_data")
  afterData     Json?         @map("after_data")
  changedBy     BigInt?       @map("changed_by")
  createdAt     DateTime      @default(now()) @map("created_at")
  changedByUser User?         @relation("HistoryChangedBy", fields: [changedBy], references: [id], onDelete: SetNull)

  @@index([tableName, recordId])
  @@index([changedBy])
  @@map("histories")
}

model RefreshToken {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt   @map("user_id")
  tokenHash String   @unique @map("token_hash") @db.VarChar(255)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}
